# Rewire App — Local Environment Variables
# Copy to .env.local and fill in values

# Supabase (auto-populated by supabase start)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# LLM Providers
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key-for-fallback

# Apple (for subscription verification)
APPLE_SHARED_SECRET=your-apple-shared-secret

# APNs (for push notifications)
APNS_KEY_ID=your-key-id
APNS_TEAM_ID=your-team-id
APNS_BUNDLE_ID=com.rewire.app

# Crisis Alerts
CRISIS_ALERT_WEBHOOK=https://hooks.slack.com/services/xxx (or PagerDuty)
ADMIN_DEVICE_TOKEN=your-admin-device-push-token

# Feature Flags
ENABLE_LLM_QUESTS=true
ENABLE_CRISIS_LLM=true
ENABLE_PUSH_NOTIFICATIONS=false
